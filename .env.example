# AIM Dashboard / Continuous Controls Monitoring environment template
# Copy to ".env" for local development, or configure these in Render.

# Required for AI custom-rule generation and SQL GPT.
OPENAI_API_KEY=your-openai-api-key-here

# Required in production. Use a long random string.
AIM_JWT_SECRET=change-me-to-a-long-random-secret

# Initial administrator account. AIM_ADMIN_PASSWORD is required in production.
AIM_ADMIN_USERNAME=admin
AIM_ADMIN_PASSWORD=change-me-to-a-strong-unique-password
AIM_ADMIN_DISPLAY_NAME=Administrator

# Production mode refuses to start without AIM_ADMIN_PASSWORD.
AIM_ENV=development

# Comma-separated allowed CORS origins.
AIM_CORS_ORIGINS=http://localhost:8001

# Optional runtime storage paths. Point these at a Render persistent disk mount
# if users, assignments, uploads, and SQL tables must survive restarts.
# AIM_DATA_DIR=/var/data/aim
# SQL_GPT_DB_DIR=/var/data/sql-gpt/databases
# SQL_GPT_UPLOAD_DIR=/var/data/sql-gpt/uploads

# Render provides PORT automatically. Local default is 8001.
# PORT=8001

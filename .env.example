# ── AIM Dashboard / Continuous Controls Monitoring — environment template ──
# Copy to ".env" for local dev, or set these in your host's dashboard (e.g. Render).

# OpenAI API key — required for SQL GPT NL→SQL queries and AI custom-rule generation
OPENAI_API_KEY=your-openai-api-key-here

# JWT signing secret — REQUIRED in production. Use a long random string.
AIM_JWT_SECRET=change-me-to-a-long-random-secret

# Comma-separated allowed CORS origins. Set to your deployed URL in production.
AIM_CORS_ORIGINS=http://localhost:8001

# Port — the host normally provides this (Render sets $PORT). Local default is 8001.
# PORT=8001
